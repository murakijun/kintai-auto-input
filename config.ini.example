[user]
# ★ 自分のOutlookメールアドレス（他の人のメールと区別するために使用）
# 例: sender_email = muraki@example.com
sender_email = your-email@example.com

[target]
# 処理対象の年と月
# "auto" のままにしておくと今月を自動で処理します（毎月変更不要）
year  = auto
month = auto

[excel_paths]
# 月ごとのExcelファイルパスを自動記録します（手動編集不要）
# 例: 2026_04 = C:\Users\yourname\Downloads\フレックス版_社員勤務報告書_...202604...xlsx
#     2026_05 = C:\Users\yourname\Downloads\フレックス版_社員勤務報告書_...202605...xlsx

[excel]
# 後方互換用（通常は excel_paths を使用）
path =

[outlook]
# Outlookフォルダ種別
# 5 = 送信済みアイテム（通常はこちら）
# 6 = 受信トレイ
folder_type = 5

[options]
# プレビューモード
# true  = Excelに書き込まず内容を確認するだけ
# false = 実際にExcelへ書き込む
preview_only = false
